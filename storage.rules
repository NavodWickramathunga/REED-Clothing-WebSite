rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images — readable by anyone, writable only by admin
    match /product-images/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null &&
                   request.auth.token.email.lower() == 'admin@reed.lk';
    }

    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
